# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=          # generate with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# The only email allowed to sign in
ADMIN_EMAIL=morgan.king@reyse.co.uk

# Talk to Rey -- hosted voice conversation
# Same keys voice-line already uses; reuse the same values, don't generate new ones.
GROQ_API_KEY=
DEEPINFRA_API_KEY=
# Same subscription-based auth as voice-line (`claude setup-token`). Unlike
# voice-line's own single-purpose script, this app can have ANTHROPIC_API_KEY
# set too for other features (e.g. Instagram automation) without conflict --
# the Talk to Rey route explicitly strips that key from just its own
# subprocess so the two billing modes don't collide.
CLAUDE_CODE_OAUTH_TOKEN=
# A GitHub personal access token scoped to read reyse-vault (repo scope),
# used only at build time to clone Rey's memory into this app.
VAULT_GITHUB_TOKEN=
