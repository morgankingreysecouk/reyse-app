// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Prefixed underlying DB object names (ra_*) -- this Postgres instance is
// shared with the old `reyse` app's ~50-model schema (same project, same
// database, not yet fully decommissioned). "EnquiryStatus" already exists
// there, confirmed the hard way (P3005 baseline attempt collided with it
// live in production). Prisma-level names stay clean (Enquiry,
// EnquiryChannel, EnquiryStatus) via @@map -- only the real SQL names are
// namespaced, so nothing above the schema file needs to know or care.
enum EnquiryChannel {
  WEBSITE
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  MANUAL

  @@map("ra_enquiry_channel")
}

enum EnquiryStatus {
  NEW
  CONTACTED
  WON
  LOST

  @@map("ra_enquiry_status")
}

model Enquiry {
  id           String         @id @default(cuid())
  fullName     String
  email        String
  phone        String
  businessName String
  message      String?

  channel      EnquiryChannel @default(WEBSITE)
  status       EnquiryStatus  @default(NEW)
  notes        String?

  // Marked true for enquiries created via "Add test enquiry" -- excluded
  // from real stats and clearly flagged in the UI, never mixed in with
  // genuine leads.
  isTest       Boolean        @default(false)

  // Soft delete only. "Delete" moves an enquiry to Trash by setting this;
  // nothing is ever hard-deleted from the UI, so an accidental delete is
  // always recoverable. A scheduled hard-purge of old trash is a future
  // decision, not something this builds silently.
  deletedAt    DateTime?

  // Set the first time status moves away from NEW -- this is what the
  // response-time stat is measured from, separate from createdAt so a
  // status changed back to NEW later doesn't corrupt the metric.
  firstRespondedAt DateTime?

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([status])
  @@index([channel])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("ra_enquiry")
}

// Live Chat -- reyse.co.uk's Claude-powered widget persists every
// conversation here (Reyse-Website's api/chat.ts calls the public API
// below). Not just enquiries: full transcripts, including conversations
// that never convert, since "most-asked questions" and real usage
// analytics need the whole picture, not just the leads.
enum ChatRole {
  USER
  ASSISTANT
  OPERATOR

  @@map("ra_chat_role")
}

enum ChatConversationStatus {
  ACTIVE
  CLOSED

  @@map("ra_chat_conversation_status")
}

// Broad, deterministic keyword buckets for "most-asked questions" --
// applied to a conversation's opening message. Not NLP/ML clustering
// (no infra for that, and it would need real training data this product
// doesn't have yet); a handful of honest keyword buckets is a real,
// truthful answer to "what do visitors actually ask about" without
// pretending to more sophistication than exists.
enum ChatTopic {
  PRICING
  HOW_IT_WORKS
  GETTING_STARTED
  OTHER

  @@map("ra_chat_topic")
}

model ChatConversation {
  id        String   @id @default(cuid())

  // Client-generated id stored in the visitor's sessionStorage -- ties every
  // message in one browser session to the same conversation without any
  // account/login on the visitor's side.
  visitorId String

  status    ChatConversationStatus @default(ACTIVE)
  topic     ChatTopic              @default(OTHER)

  // Set true the moment the AI's send_enquiry tool actually fires for this
  // conversation -- this is what the conversion-rate stat is measured
  // against, distinct from whether Morgan has since actioned it.
  convertedToEnquiry Boolean @default(false)

  notes     String?

  // Soft delete only, same pattern as Enquiry -- never hard-deleted from
  // the UI, always recoverable via restore.
  deletedAt DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  messages ChatMessage[]

  @@index([status])
  @@index([deletedAt])
  @@index([lastMessageAt])
  @@index([visitorId])
  @@map("ra_chat_conversation")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  conversation   ChatConversation @relation(fields: [conversationId], references: [id])

  role    ChatRole
  content String

  createdAt DateTime @default(now())

  @@index([conversationId])
  @@map("ra_chat_message")
}

// Single-row table -- the grounding facts (pricing, features, how it
// works) the chat's system prompt is built from. Editable from the admin
// UI instead of only in code, so pricing changes don't need a deploy.
// Reyse-Website's api/chat.ts fetches the current content on every
// request (with a hardcoded fallback if reyse-app is unreachable).
model ChatKnowledge {
  id        String   @id @default(cuid())
  content   String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("ra_chat_knowledge")
}
